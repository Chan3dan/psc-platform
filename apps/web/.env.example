# ============================================================
# PSC PLATFORM — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/psc-platform
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/psc-platform
MONGODB_URI=mongodb://localhost:27017/psc-platform

# ── NextAuth ─────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-32-character-string-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Redis ────────────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash REST: https://<host>.upstash.io + token below
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudinary (PDF/Image uploads) ───────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Niyukta
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CORS (comma-separated origins for production) ────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
